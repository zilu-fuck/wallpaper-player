{
  "name": "wallpaper-player",
  "version": "1.1.2",
  "description": "本地视频画廊播放器 - 浏览、搜索、播放本地视频文件",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare-vendor": "node scripts/prepare-vendor.js",
    "start": "npm run build && electron .",
    "rebuild": "vite build && electron .",
    "pack:win": "npm run build && npm run prepare-vendor && electron-builder --win --dir",
    "dist:win": "npm run build && npm run prepare-vendor && node scripts/package-win.js"
  },
  "build": {
    "appId": "com.wallpaper.player",
    "productName": "Wallpaper Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "mpv.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor",
        "filter": [
          "**/*",
          "!_downloads/**",
          "!**/*.pdb",
          "!ffmpeg/doc/**"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Wallpaper-Player-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "Wallpaper-Player-${version}.${ext}"
    },
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "zilu-fuck",
        "repo": "wallpaper-player"
      }
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  }
}
