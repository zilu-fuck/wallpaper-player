{
  "name": "wallpaper-player",
  "version": "1.3.3",
  "description": "本地视频画廊播放器 - 浏览、搜索、播放本地视频文件",
  "license": "Apache-2.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare-vendor": "node scripts/prepare-vendor.js",
    "start": "npm run build && node scripts/start-electron-direct.js",
    "start:direct": "node scripts/start-electron-direct.js",
    "rebuild": "vite build && node scripts/start-electron-direct.js",
    "verify:remote-mobile": "node scripts/verify-remote-mobile.js",
    "verify:remote-settings": "node scripts/verify-remote-settings.js",
    "verify:remote-api": "node scripts/verify-remote-api-smoke.js",
    "verify:remote-library": "node scripts/verify-remote-library-flow.js",
    "verify:thumbnail-playback": "node scripts/verify-thumbnail-playback-throttle.js",
    "verify:plugin-official": "electron scripts/verify-official-plugin-sync.js",
    "verify:ai-search": "node scripts/verify-ai-search.js",
    "verify:plugins": "node scripts/verify-plugin-registry.js",
    "verify:plugin-remote": "node scripts/verify-plugin-remote-route.js",
    "verify:plugin-video": "electron scripts/verify-plugin-video-lifecycle.js",
    "verify:plugin-external": "electron scripts/verify-external-plugin-lifecycle.js",
    "verify:plugin-package": "electron scripts/verify-plugin-package-install.js",
    "verify:vlm-ui": "electron scripts/verify-vlm-start-button-ui.js",
    "verify:startup": "node scripts/verify-direct-startup.js",
    "verify:remote-pressure": "node scripts/verify-remote-pressure.js",
    "verify:mobile-multi-device": "node scripts/verify-mobile-multi-device.js",
    "verify:mobile-player": "node scripts/verify-mobile-player-structure.js",
    "verify:video-metadata": "node scripts/verify-video-metadata-cache.js",
    "verify:mobile-transcode": "node scripts/verify-transcode-command.js",
    "verify:mobile-transcode-concurrency": "node scripts/verify-transcode-concurrency.js",
    "verify:mobile-lan": "npm run verify:remote-mobile && npm run verify:remote-settings && npm run verify:remote-api && npm run verify:remote-library && npm run verify:mobile-multi-device && npm run verify:mobile-player && npm run verify:mobile-transcode && npm run verify:mobile-transcode-concurrency",
    "pack:plugins": "node scripts/package-plugins.js",
    "pack:win": "npm run build && npm run prepare-vendor && electron-builder --win --dir && npm run pack:plugins",
    "dist:win": "npm run build && npm run prepare-vendor && node scripts/package-win.js"
  },
  "build": {
    "appId": "com.wallpaper.player",
    "productName": "Wallpaper Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "main/**/*",
      "!main/plugins/video-analysis/**",
      "!main/plugins/ai-search/**",
      "!main/plugins/agent-bridge/**",
      "!main/video-comprehension-runtime/**",
      "mpv.js",
      "preload.js",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "licenses/**/*",
      "sources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor",
        "filter": [
          "**/*",
          "!_downloads/**",
          "!**/*.pdb",
          "!ffmpeg/doc/**",
          "!llama.cpp/**",
          "!llama.cpp-cuda/**"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Wallpaper-Player-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "license": "LICENSE",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "Wallpaper-Player-${version}.${ext}"
    },
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "zilu-fuck",
        "repo": "wallpaper-player"
      }
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "qrcode": "^1.5.4"
  },
  "optionalDependencies": {
    "playwright-core": "^1.61.1"
  }
}
